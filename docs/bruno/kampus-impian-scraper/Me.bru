example {
  name: 401

  request: {
    url: http://localhost:8000/api/auth/me
    method: GET
  }

  response: {
    status: {
      code: 401
      text: Unauthorized
    }

    body: {
      type: json
      content: '''
        {"detail":"Not authenticated"}
      '''
    }
  }
}
